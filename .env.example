# נתיב בסיס לאפליקציה
VITE_BASE_PATH=/

# ── שער סיסמה (מאובטח) ──
# הסיסמה PASS_W לא נכנסת לקוד האתר — רק לשרת Cloudflare Worker (worker/)
#
# 1) פרוס את ה-Worker:
#      cd worker
#      npx wrangler login
#      npx wrangler secret put PASS_W
#      npx wrangler deploy
#
# 2) העתק את כתובת ה-Worker (למשל https://couple-spin-auth.xxx.workers.dev)
#    והדבק כאן:
VITE_AUTH_API_URL=
#
# 3) ב-GitHub: Settings → Variables → Actions
#    שם: VITE_AUTH_API_URL   ערך: כתובת ה-Worker
#
# PASS_W נשמר רק ב-Cloudflare:
#    cd worker && npx wrangler secret put PASS_W

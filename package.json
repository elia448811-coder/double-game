{
  "name": "couple-spin",
  "private": true,
  "version": "1.0.0",
  "description": "ספין זוגי — משחק משימות כיפי לזוגות",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:system": "node scripts/test-system.mjs",
    "test:layouts": "node scripts/test-device-layouts.mjs",
    "test:watch": "vitest",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy:build": "node scripts/build-production.mjs",
    "deploy:preview": "npm run deploy:build && vite preview --host"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
